# App Configuration
VITE_API_BASE_URL=http://localhost:5000/api

# Note: Any variable used in the frontend must start with VITE_

# --- GOOGLE MAPS ---
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# --- META (FACEBOOK) PIXEL ---
# Replace with your 15-digit Meta Pixel ID from Events Manager (e.g., VITE_META_PIXEL_ID=123456789012345)
VITE_META_PIXEL_ID=your_meta_pixel_id_here

# --- FIREBASE (Client Auth) ---
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
