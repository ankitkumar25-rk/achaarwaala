# ==============================================================================
# PHOTOWALAGIFT BACKEND ENVIRONMENT VARIABLES (.env.example)
# ==============================================================================

# --- SERVER ---
NODE_ENV=production
PORT=5000
HOST=0.0.0.0
# The frontend URLs for CORS (No trailing slashes)
CLIENT_URL=https://photowalagift.online
ADMIN_URL=https://admin.photowalagift.online

# --- DATABASE (PostgreSQL) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- CACHE & SESSIONS (Valkey / Redis) ---
# Use VALKEY_URL for Upstash/Valkey (supports TLS)
VALKEY_URL=rediss://default:PASSWORD@your-db.upstash.io:6379
# Fallback for generic Redis
REDIS_URL=redis://localhost:6379

# --- AUTH (PASETO) ---
# Generate a 32-byte hex key: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
PASETO_SECRET_KEY=64_hex_chars_representing_32_bytes
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# --- FIREBASE ADMIN (Backend Auth Verification) ---
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
# For FIREBASE_PRIVATE_KEY, remember to replace actual newlines with \n in your .env
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Private_Key\n-----END PRIVATE KEY-----\n"

# --- RAZORPAY ---
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret


# --- CLOUDINARY ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- EMAIL (SMTP - Gmail or Custom) ---
# For Gmail: https://support.google.com/accounts/answer/185833
# 1. Enable 2-factor authentication on your Gmail account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use the generated 16-character password as SMTP_PASS
SMTP_SERVICE=gmail
# Alternatively, for custom SMTP servers:
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_SECURE=false
SMTP_USER=photowalagiftphotowalagift@gmail.com
SMTP_PASS=your_16_character_app_password
FROM_EMAIL=Photowala Gift <your_email@gmail.com>
ADMIN_EMAIL=photowalagiftphotowalagift@gmail.com

# --- GOOGLE MAPS (Places & Address Validation) ---
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# --- RATE LIMITING ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=5000

# --- COOKIE CONFIG ---
# Use .photowalagift.online to share cookies across subdomains
COOKIE_DOMAIN=.photowalagift.online
